/* Generated from version.h.in by CMake at configure time.
 *
 * Single source of truth: cozip/VERSION (CalVer YYYY.M.D).
 *
 * Do NOT edit this file directly — change cozip/VERSION instead.
 */

#ifndef COZIP_VERSION_H
#define COZIP_VERSION_H

#define COZIP_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define COZIP_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define COZIP_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define COZIP_VERSION_STRING "@PROJECT_VERSION@"

#ifdef __cplusplus
extern "C" {
#endif

#include "cozip.h"  /* for COZIP_API */

/* Returns the cozip version as "MAJOR.MINOR.PATCH".
 *
 * Resolvable from a dlopen'd library (Python/R/Julia FFI bindings use
 * this to confirm they loaded the .so/.dylib/.dll matching their
 * package metadata). */
COZIP_API const char* cozip_version_string(void);

#ifdef __cplusplus
}
#endif

#endif /* COZIP_VERSION_H */