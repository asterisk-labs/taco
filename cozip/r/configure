#!/bin/sh
# configure script for cozip — runs before R CMD INSTALL compiles src/.
#
# Why this exists: pak (used by r-universe) doesn't have a libzip
# rule in r-system-requirements, so SystemRequirements alone doesn't
# trigger apt-get install libzip-dev. This script installs it as a
# fallback. In environments where libzip is already present (CI
# containers with libzip-dev preinstalled, dev workstations, etc),
# the install is a no-op.

set -e

# Probe libzip via pkg-config first. If found, nothing to do.
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libzip; then
    LIBZIP_VERSION=$(pkg-config --modversion libzip)
    echo "configure: found libzip $LIBZIP_VERSION via pkg-config"
    exit 0
fi

echo "configure: libzip not found, attempting to install..."

# Detect package manager and install. We avoid sudo because r-universe
# and most build containers run as root; on dev workstations the user
# can pre-install libzip themselves.
if command -v apt-get >/dev/null 2>&1; then
    apt-get update -qq
    apt-get install -y --no-install-recommends libzip-dev pkg-config
elif command -v yum >/dev/null 2>&1; then
    yum install -y libzip-devel pkgconf
elif command -v dnf >/dev/null 2>&1; then
    dnf install -y libzip-devel pkgconf
elif command -v zypper >/dev/null 2>&1; then
    zypper install -y libzip-devel pkg-config
elif command -v brew >/dev/null 2>&1; then
    brew install libzip pkg-config
else
    echo "configure: ERROR - libzip not found and no known package manager available."
    echo "  Please install libzip-dev (or equivalent) manually:"
    echo "    Debian/Ubuntu: apt-get install libzip-dev"
    echo "    RHEL/Fedora:   yum install libzip-devel"
    echo "    macOS:         brew install libzip"
    exit 1
fi

# Verify the install worked.
if ! pkg-config --exists libzip; then
    echo "configure: ERROR - libzip install completed but pkg-config still can't find it."
    exit 1
fi

LIBZIP_VERSION=$(pkg-config --modversion libzip)
echo "configure: installed libzip $LIBZIP_VERSION"